{
  "name": "danger-plugin-toolbox",
  "version": "4.0.0",
  "description": "Danger Plugin Toolbox is a Danger JS plugin containing a set of common validations and utilities, build to make it easy to start using Danger JS.",
  "license": "MIT",
  "engines": {
    "node": ">=22.13.1",
    "npm": ">=10.9.2"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:sogame/danger-plugin-toolbox.git"
  },
  "bugs": {
    "url": "https://github.com/sogame/danger-plugin-toolbox/issues"
  },
  "homepage": "https://github.com/sogame/danger-plugin-toolbox#readme",
  "author": {
    "email": "sogame@gmail.com",
    "name": "Sogame"
  },
  "keywords": [
    "danger",
    "danger-plugin"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "babel src --out-dir dist --ignore **/__tests__/,**/__fixtures__/,**/__mocks__/",
    "danger": "danger ci --failOnErrors",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:fix:staged": "eslint --fix",
    "lint:staged": "eslint",
    "prepare": "husky",
    "release": "node ./scripts/release.js",
    "test": "jest --silent=false",
    "test:coverage": "npm test -- --coverage",
    "test:watch": "npm test -- --watch",
    "update:changelog": "node ./scripts/update-changelog"
  },
  "lint-staged": {
    "**/!(package-lock).json": "prettier --write",
    "**/*.js": [
      "prettier --write",
      "npm run lint:fix:staged --"
    ],
    "**/*.md": "prettier --write",
    "**/*.yml": "prettier --write"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.js",
      "!**/__fixtures__/**",
      "!src/utils/index.js",
      "!src/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    },
    "setupFilesAfterEnv": [
      "<rootDir>/setupTests.js"
    ]
  },
  "devDependencies": {
    "@babel/cli": "^8.0.1",
    "@babel/preset-env": "^8.0.2",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/js": "^10.0.1",
    "ajv": "^8.20.0",
    "babel-jest": "^30.4.1",
    "danger": "^13.0.10",
    "eslint": "^10.6.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "inquirer": "^14.0.2",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "release-it": "^20.2.1"
  }
}
